---
import { Image } from 'astro:assets';
import { NAV_LINKS, SITE } from '../lib/site';
import wordmark from '../assets/logo/wordmark.png';

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-50">
	<div class="px-gutter mx-auto max-w-6xl py-12">
		<div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
			<div class="space-y-2">
				<Image src={wordmark} alt="madebyjustas" width={288} loading="lazy" class="h-6 w-auto" />
				<a
					href={`mailto:${SITE.email}`}
					class="duration-base ease-standard hover:text-neutral-900 block font-sans text-sm text-neutral-600 transition-colors"
				>
					{SITE.email}
				</a>
				<a
					href={SITE.linkedin}
					target="_blank"
					rel="noopener noreferrer"
					class="duration-base ease-standard hover:text-neutral-900 block font-sans text-sm text-neutral-600 transition-colors"
				>
					LinkedIn
				</a>
			</div>

			<nav aria-label="Footer" class="grid grid-cols-2 gap-x-8 gap-y-2 sm:grid-cols-3">
				{
					NAV_LINKS.map((link) => (
						<a
							href={link.href}
							class="duration-base ease-standard font-sans text-sm text-neutral-600 transition-colors hover:text-neutral-900"
						>
							{link.label}
						</a>
					))
				}
			</nav>
		</div>

		<p class="mt-12 font-sans text-xs text-neutral-500">
			{`© ${year} ${SITE.author}. All rights reserved.`}
		</p>
	</div>
</footer>
