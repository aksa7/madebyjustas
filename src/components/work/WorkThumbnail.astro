---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	alt: string;
	loading?: 'eager' | 'lazy';
	sizes?: string;
	class?: string;
	fit?: 'cover' | 'contain';
}

const {
	image,
	alt,
	loading = 'lazy',
	sizes = '(min-width: 640px) 560px, 100vw',
	class: className = '',
	fit = 'cover',
} = Astro.props;

const imageClass = fit === 'contain' ? 'object-contain' : 'object-cover';
const frameClass =
	fit === 'contain' ? 'bg-neutral-900' : 'bg-neutral-100';
---

<div
	class:list={[
		'aspect-video overflow-hidden rounded-md border border-neutral-200',
		frameClass,
		className,
	]}
>
	<Image
		src={image}
		alt={alt}
		widths={[420, 640, 960, 1280]}
		sizes={sizes}
		loading={loading}
		decoding={loading === 'eager' ? 'auto' : 'async'}
		fetchpriority={loading === 'eager' ? 'high' : 'auto'}
		class:list={['h-full w-full', imageClass]}
	/>
</div>
