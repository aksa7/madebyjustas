---
import WorkThumbnail from './WorkThumbnail.astro';
import type { WorkProject } from '../../lib/content';

interface Props {
	project: WorkProject;
}

const { project } = Astro.props;
---

<section class="px-gutter mx-auto max-w-6xl pt-16 pb-12 sm:pt-24">
	<p class="text-accent-600 font-sans text-sm tracking-wide uppercase">
		{project.category} · {project.year}
	</p>
	<h1 class="font-display mt-3 max-w-4xl text-5xl sm:text-6xl">{project.name}</h1>
	<p class="mt-2 font-sans text-base text-neutral-500">{project.role}</p>

	<p class="mt-6 max-w-2xl font-sans text-lg text-neutral-600 sm:text-xl">
		{project.summary}
	</p>

	<ul class="mt-6 flex flex-wrap gap-2">
		{
			project.stack.map((item) => (
				<li class="rounded-full border border-neutral-200 px-3 py-1 font-sans text-xs text-neutral-600">
					{item}
				</li>
			))
		}
	</ul>

	{
		project.url && (
			<a
				href={project.url}
				target="_blank"
				rel="noopener noreferrer"
				class="bg-accent-500 duration-fast ease-standard hover:bg-accent-600 active:bg-accent-700 active:scale-[0.98] focus-visible:outline-accent-400 mt-6 inline-flex items-center gap-2 rounded-full px-5 py-2.5 font-sans text-sm font-medium text-white transition-[background-color,transform] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
			>
				Visit site
				<span aria-hidden="true">↗</span>
			</a>
		)
	}

	<WorkThumbnail
		image={project.image}
		alt={project.imageAlt}
		loading="eager"
		sizes="(min-width: 1152px) 1152px, 100vw"
		class="mt-12"
	/>
</section>
