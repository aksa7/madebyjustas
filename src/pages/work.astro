---
import BaseLayout from '../layouts/BaseLayout.astro';
import Reveal from '../components/Reveal.astro';
import WorkCard from '../components/work/WorkCard.astro';
import JsonLd from '../components/JsonLd.astro';
import { WORK_PROJECTS } from '../lib/content';
import { SITE } from '../lib/site';

const delayClasses = ['', 'delay-150', 'delay-300'];

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
		{ '@type': 'ListItem', position: 2, name: 'Work', item: `${SITE.url}/work` },
	],
};
---

<BaseLayout
	title="Work"
	description="Selected projects across platforms, products, service businesses, agencies, and events. Fast, hand-coded sites built to get found."
>
	<section class="px-gutter pb-section mx-auto max-w-6xl pt-16 sm:pt-24">
		<h1 class="font-display max-w-3xl text-5xl sm:text-6xl">Work</h1>
		<Reveal class="mt-6 max-w-2xl">
			<p class="font-sans text-lg text-neutral-600 sm:text-xl">
				Platforms, products, service businesses, agencies and events. Real projects, built to be
				fast and easy to find.
			</p>
		</Reveal>

		<div class="mt-16 grid gap-12 sm:grid-cols-2">
			{
				WORK_PROJECTS.map((project, index) => (
					<Reveal class={delayClasses[index % delayClasses.length]}>
						<WorkCard project={project} eager={index < 2} />
					</Reveal>
				))
			}
		</div>

		<Reveal class="mt-16 border-t border-neutral-200 pt-8">
			<p class="font-sans text-base text-neutral-500">
				and many more. Over 20 websites shipped, from solo-operator clinics to multi-location
				businesses.
			</p>
		</Reveal>
	</section>
	<JsonLd schema={breadcrumbSchema} />
</BaseLayout>
