---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata;
	alt: string;
	loading?: 'eager' | 'lazy';
	sizes?: string;
	class?: string;
}

const {
	image,
	alt,
	loading = 'lazy',
	sizes = '(min-width: 640px) 560px, 100vw',
	class: className = '',
} = Astro.props;
---

<div
	class:list={[
		'aspect-video overflow-hidden rounded-md border border-neutral-200 bg-neutral-100',
		className,
	]}
>
	<Image
		src={image}
		alt={alt}
		widths={[420, 640, 960, 1280]}
		sizes={sizes}
		loading={loading}
		decoding={loading === 'eager' ? 'auto' : 'async'}
		fetchpriority={loading === 'eager' ? 'high' : 'auto'}
		class="h-full w-full object-cover"
	/>
</div>
