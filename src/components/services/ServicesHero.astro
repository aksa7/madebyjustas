---
import Reveal from '../Reveal.astro';
---

<section class="px-gutter pb-section mx-auto max-w-6xl pt-16 sm:pt-24">
	<h1 class="font-display max-w-4xl text-5xl sm:text-6xl lg:text-7xl">
		Fast, AI-optimized websites for service businesses.
	</h1>

	<Reveal class="mt-6 max-w-2xl">
		<p class="font-sans text-lg text-neutral-600 sm:text-xl">
			No agency overhead. Direct communication. Clear scope.
		</p>
	</Reveal>
</section>
