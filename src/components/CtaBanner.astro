---
import Button from './Button.astro';
import Reveal from './Reveal.astro';
import { GRAIN_BACKGROUND } from '../lib/decor';

interface Props {
	eyebrow?: string;
	heading: string;
	buttonLabel?: string;
	buttonHref?: string;
}

const { eyebrow, heading, buttonLabel = 'Contact', buttonHref = '/contact' } = Astro.props;
---

<section class="relative isolate overflow-hidden border-t border-neutral-200 bg-neutral-100">
	<div
		aria-hidden="true"
		class="absolute inset-0 opacity-[0.05] mix-blend-multiply"
		style={{ backgroundImage: `url("${GRAIN_BACKGROUND}")` }}
	>
	</div>

	<div class="px-gutter py-section relative mx-auto max-w-6xl text-center">
		<Reveal>
			{
				eyebrow && (
					<p class="text-neutral-600 font-sans text-sm tracking-wide uppercase">{eyebrow}</p>
				)
			}
			<h2 class:list={['font-display text-3xl sm:text-4xl', eyebrow ? 'mt-3' : '']}>{heading}</h2>
		</Reveal>

		<Reveal class="mt-8 delay-150">
			<Button href={buttonHref} variant="primary">{buttonLabel}</Button>
		</Reveal>
	</div>
</section>
