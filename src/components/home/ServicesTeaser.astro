---
import Reveal from '../Reveal.astro';
import { SERVICES } from '../../lib/content';

const delayClasses = ['', 'delay-150', 'delay-300'];
---

<section class="px-gutter py-section mx-auto max-w-6xl">
	<Reveal>
		<h2 class="font-display text-3xl sm:text-4xl">Services</h2>
	</Reveal>

	<div class="mt-12 grid gap-8 sm:grid-cols-3">
		{
			SERVICES.map((service, index) => (
				<Reveal class={delayClasses[index]}>
					<article class="h-full rounded-md border border-neutral-200 bg-white p-8 shadow-sm">
						<p class="font-display text-accent-500 text-2xl">{service.number}</p>
						<h3 class="font-display mt-4 text-xl text-neutral-900">{service.name}</h3>
						<p class="mt-3 font-sans text-sm text-neutral-600">{service.summary}</p>
						<p class="mt-4 font-sans text-xs tracking-wide text-neutral-500 uppercase">
							{service.duration}
						</p>
					</article>
				</Reveal>
			))
		}
	</div>

	<Reveal class="mt-10 delay-300">
		<a
			href="/services"
			class="decoration-accent-400 duration-base ease-standard hover:text-accent-600 inline-flex items-center gap-2 font-sans text-sm font-medium text-neutral-900 underline decoration-2 underline-offset-4 transition-colors"
		>
			See all services →
		</a>
	</Reveal>
</section>
