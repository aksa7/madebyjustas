---
interface Props {
	id: string;
	label: string;
}

const { id, label } = Astro.props;
---

<div class="flex flex-col gap-1.5">
	<label for={id} class="font-sans text-sm font-medium text-neutral-900">{label}</label>
	<slot />
	<p id={`${id}-error`} class="text-danger min-h-5 font-sans text-xs" role="alert"></p>
</div>
