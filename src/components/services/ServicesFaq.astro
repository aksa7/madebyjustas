---
import Reveal from '../Reveal.astro';
import { SERVICES_FAQ } from '../../lib/content';
---

<section class="px-gutter py-section mx-auto max-w-6xl">
	<Reveal>
		<h2 class="font-display text-3xl sm:text-4xl">Frequently asked questions</h2>
	</Reveal>

	<Reveal class="delay-150">
		<div class="mt-12 divide-y divide-neutral-200 border-t border-b border-neutral-200">
			{
				SERVICES_FAQ.map((item) => (
					<details class="group py-6">
						<summary class="focus-visible:outline-accent-500 flex cursor-pointer list-none items-center justify-between gap-4 font-sans text-base font-medium text-neutral-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 [&::-webkit-details-marker]:hidden">
							{item.question}
							<span
								class="text-accent-500 duration-base ease-standard shrink-0 transition-transform group-open:rotate-180"
								aria-hidden="true"
							>
								⌄
							</span>
						</summary>
						<p class="mt-4 max-w-2xl font-sans text-sm text-neutral-600">{item.answer}</p>
					</details>
				))
			}
		</div>
	</Reveal>
</section>
