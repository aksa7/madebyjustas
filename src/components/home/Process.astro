---
import Reveal from '../Reveal.astro';
import { PROCESS_STEPS } from '../../lib/content';

const delayClasses = ['', 'delay-150', 'delay-300'];
---

<section class="px-gutter py-section mx-auto max-w-6xl">
	<Reveal>
		<h2 class="font-display text-3xl sm:text-4xl">Process</h2>
	</Reveal>

	<div class="mt-12 grid gap-12 sm:grid-cols-3">
		{
			PROCESS_STEPS.map((step, index) => (
				<Reveal class={delayClasses[index]}>
					<div class="border-accent-400 border-t-2 pt-6">
						<p class="font-sans text-sm tracking-widest text-neutral-500 uppercase">
							{step.number}
						</p>
						<h3 class="font-display mt-2 text-2xl text-neutral-900">{step.name}</h3>
						<p class="mt-3 font-sans text-sm text-neutral-600">{step.description}</p>
					</div>
				</Reveal>
			))
		}
	</div>
</section>
