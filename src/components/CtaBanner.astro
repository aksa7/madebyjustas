---
import Button from './Button.astro';
import Reveal from './Reveal.astro';

interface Props {
	eyebrow?: string;
	heading: string;
	buttonLabel?: string;
	buttonHref?: string;
}

const { eyebrow, heading, buttonLabel = 'Contact', buttonHref = '/contact' } = Astro.props;
---

<section class="border-t border-neutral-200 bg-neutral-100">
	<div class="px-gutter py-section mx-auto max-w-6xl text-center">
		<Reveal>
			{
				eyebrow && (
					<p class="text-accent-600 font-sans text-sm tracking-wide uppercase">{eyebrow}</p>
				)
			}
			<h2 class:list={['font-display text-3xl sm:text-4xl', eyebrow ? 'mt-3' : '']}>{heading}</h2>
		</Reveal>

		<Reveal class="mt-8 delay-150">
			<Button href={buttonHref} variant="primary">{buttonLabel}</Button>
		</Reveal>
	</div>
</section>
