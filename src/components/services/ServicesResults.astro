---
import Reveal from '../Reveal.astro';
import { RESULT_STATS } from '../../lib/content';
---

<section class="px-gutter mx-auto max-w-6xl">
	<Reveal>
		<div class="grid grid-cols-2 gap-px overflow-hidden rounded-md border border-neutral-200 bg-neutral-200 sm:grid-cols-4">
			{
				RESULT_STATS.map((stat) => (
					<div class="flex flex-col gap-1 bg-white px-6 py-8 text-center">
						<p class="font-display text-accent-500 text-4xl font-semibold tracking-tight sm:text-5xl">
							{stat.value}
						</p>
						<p class="font-sans text-sm text-neutral-500">{stat.label}</p>
					</div>
				))
			}
		</div>
	</Reveal>
</section>
