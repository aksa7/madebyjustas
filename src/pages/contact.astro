---
import BaseLayout from '../layouts/BaseLayout.astro';
import Reveal from '../components/Reveal.astro';
import FormField from '../components/form/FormField.astro';
import SubmitButton from '../components/form/SubmitButton.astro';
import { SITE } from '../lib/site';
import { SERVICES } from '../lib/content';

const inputClass =
	'rounded-md border border-neutral-300 bg-white px-4 py-2.5 font-sans text-base text-neutral-900 transition-colors duration-base ease-standard placeholder:text-neutral-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent-500 data-[invalid=true]:border-danger';
---

<BaseLayout
	title="Contact"
	description="Accepting 2 new projects for Q3 2026. Get in touch to discuss your project."
>
	<section class="px-gutter mx-auto max-w-6xl pt-16 pb-12 sm:pt-24">
		<p class="text-neutral-600 font-sans text-sm tracking-wide uppercase">Availability</p>
		<h1 class="font-display mt-3 max-w-3xl text-5xl sm:text-6xl">
			Accepting 2 new projects for Q3 2026.
		</h1>

		<Reveal class="mt-6 max-w-2xl">
			<p class="font-sans text-lg text-neutral-600 sm:text-xl">
				Tell me about your project below, or email directly at{' '}
				<a
					href={`mailto:${SITE.email}`}
					class="decoration-accent-500 duration-base ease-standard hover:text-accent-600 underline decoration-2 underline-offset-4 transition-colors"
				>
					{SITE.email}
				</a>.
			</p>
		</Reveal>
	</section>

	<section class="px-gutter py-section mx-auto max-w-6xl">
		<Reveal class="delay-150">
			<form data-async-form="contact" class="max-w-xl space-y-6" novalidate>
				<input type="hidden" name="_subject" value="New project inquiry via madebyjustas.dev" />
				<input
					type="text"
					name="_gotcha"
					tabindex="-1"
					autocomplete="off"
					class="hidden"
					aria-hidden="true"
				/>
				<FormField id="contact-name" label="Name">
					<input
						id="contact-name"
						name="name"
						type="text"
						autocomplete="name"
						required
						aria-describedby="contact-name-error"
						class={inputClass}
					/>
				</FormField>

				<FormField id="contact-email" label="Email">
					<input
						id="contact-email"
						name="email"
						type="email"
						autocomplete="email"
						required
						aria-describedby="contact-email-error"
						class={inputClass}
					/>
				</FormField>

				<FormField id="contact-project-type" label="Project type">
					<select
						id="contact-project-type"
						name="projectType"
						required
						aria-describedby="contact-project-type-error"
						class={inputClass}
					>
						<option value="" selected disabled>Select an option</option>
						{SERVICES.map((service) => <option value={service.name}>{service.name}</option>)}
						<option value="Not sure yet">Not sure yet</option>
					</select>
				</FormField>

				<FormField id="contact-message" label="Message">
					<textarea
						id="contact-message"
						name="message"
						rows="5"
						minlength="20"
						required
						aria-describedby="contact-message-error"
						class={inputClass}></textarea>
				</FormField>

				<SubmitButton label="Send message" />
			</form>

			<p
				data-form-status="contact"
				role="status"
				aria-live="polite"
				class="data-[state=error]:text-danger data-[state=success]:text-success mt-6 max-w-xl font-sans text-sm"
			>
			</p>
		</Reveal>
	</section>

	<script>
		import { initAsyncForm } from '../lib/async-form';
		import { CONTACT_FORM_ENDPOINT, SITE } from '../lib/site';

		const form = document.querySelector<HTMLFormElement>('[data-async-form="contact"]');
		const status = document.querySelector<HTMLElement>('[data-form-status="contact"]');

		if (form && status) {
			initAsyncForm(form, status, CONTACT_FORM_ENDPOINT, {
				success: "Thanks, I'll get back to you within 1 business day.",
				error: `Something went wrong. Please try again, or email ${SITE.email} directly.`,
			});
		}
	</script>
</BaseLayout>
