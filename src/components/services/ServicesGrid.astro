---
import Reveal from '../Reveal.astro';
import { SERVICES, PRICING_NOTE } from '../../lib/content';

const delayClasses = ['', 'delay-150', 'delay-300'];
---

<section class="px-gutter py-section mx-auto max-w-6xl">
	<Reveal>
		<h2 class="font-display text-3xl sm:text-4xl">Formats</h2>
	</Reveal>

	<div class="mt-12 grid gap-8 sm:grid-cols-3">
		{
			SERVICES.map((service, index) => (
				<Reveal class={delayClasses[index]}>
					<article class="duration-base ease-standard hover:border-accent-300 flex h-full flex-col rounded-md border border-neutral-200 bg-white p-8 shadow-sm transition-[box-shadow,border-color] hover:shadow-md">
						<p class="font-display text-accent-500 text-2xl">{service.number}</p>
						<h3 class="font-display mt-4 text-xl text-neutral-900">{service.name}</h3>
						<ul class="mt-6 flex-1 space-y-2">
							{service.deliverables.map((item) => (
								<li class="flex gap-2 font-sans text-sm text-neutral-600">
									<span class="text-accent-400" aria-hidden="true">
										–
									</span>
									{item}
								</li>
							))}
						</ul>
						<p class="mt-6 font-sans text-xs tracking-wide text-neutral-500 uppercase">
							{service.duration}
						</p>
						<p class="mt-2 font-sans text-xs text-neutral-500">{PRICING_NOTE}</p>
					</article>
				</Reveal>
			))
		}
	</div>
</section>
